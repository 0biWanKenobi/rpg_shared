{
  "name": "rpg_shared",
  "version": "1.0.0",
  "description": "Shared lib for `rpg_master_plugin` and `rpg_player_plugin`",
  "license": "ISC",
  "author": "Obi Wan Kenobi",
  "type": "module",
  "exports": {
    "./settings/interfaces": {
      "types": "./dist/settings/interfaces.d.ts",
      "import": "./dist/settings/interfaces.js",
      "require": "./dist/settings/interfaces.cjs"
    },
    "./settings/plugin": {
      "types": "./dist/settings/plugin.d.ts",
      "import": "./dist/settings/plugin.js",
      "require": "./dist/settings/plugin.cjs"
    },
    "./ui/confirmModal": {
      "types": "./dist/ui/confirmModal.d.ts",
      "import": "./dist/ui/confirmModal.js",
      "require": "./dist/ui/confirmModal.cjs"
    },
    "./ui/tabs": {
      "types": "./dist/ui/tabs.d.ts",
      "import": "./dist/ui/tabs.js",
      "require": "./dist/ui/tabs.cjs"
    },
    "./ui/headerWithIcon": {
      "types": "./dist/ui/headerWithIcon.d.ts",
      "import": "./dist/ui/headerWithIcon.js",
      "require": "./dist/ui/headerWithIcon.cjs"
    },
    "./ui/iconButton": {
      "types": "./dist/ui/iconButton.d.ts",
      "import": "./dist/ui/iconButton.js",
      "require": "./dist/ui/iconButton.cjs"
    },
    "./styles.css": "./dist/rpg_shared.css"
  },
  "typesVersions": {
    "*": {
      "settings/interfaces": [
        "dist/settings/interfaces.d.ts"
      ],
      "settings/plugin": [
        "dist/settings/plugin.d.ts"
      ],
      "ui/confirmModal": [
        "dist/ui/confirmModal.d.ts"
      ],
      "ui/tabs": [
        "dist/ui/tabs.d.ts"
      ],
      "ui/headerWithIcon": [
        "dist/ui/headerWithIcon.d.ts"
      ],
      "ui/iconButton": [
        "dist/ui/iconButton.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch --mode development",
    "dev:yalc": "PUSH_YALC_ON_WATCH=1 npm run dev",
    "build": "vite build",
    "yalc:publish": "npm run build && ${YALC_BIN:-$HOME/.local/bin/yalc} publish",
    "yalc:push": "npm run build && ${YALC_BIN:-$HOME/.local/bin/yalc} push"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "obsidian": "^1.12.3",
    "typescript": "^5.8.3",
    "unplugin-dts": "^1.0.0-beta.6",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@preact/signals": "^2.8.2"
  }
}
